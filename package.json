{
  "name": "gitlab-ci-pipeline-visualizer",
  "displayName": "GitLab CI Pipeline Visualizer",
  "description": "Visualize your GitLab CI pipeline — expand includes, see stages and jobs at a glance",
  "version": "0.1.0",
  "publisher": "GitLabCIVisualizer",
  "repository": {
    "type": "git",
    "url": "https://github.com/chenyao0910/gitlab-ci-visualizer"
  },
  "bugs": {
    "url": "https://github.com/chenyao0910/gitlab-ci-visualizer/issues"
  },
  "homepage": "https://github.com/chenyao0910/gitlab-ci-visualizer#readme",
  "license": "MIT",
  "keywords": [
    "gitlab",
    "ci",
    "pipeline",
    "visualizer",
    "yaml"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitlab-ci-panel",
          "title": "GitLab CI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "gitlab-ci-panel": [
        {
          "type": "webview",
          "id": "gitlabCiVisualizer.sidebar",
          "name": "Pipeline Visualizer"
        }
      ]
    },
    "commands": [
      {
        "command": "gitlabCiVisualizer.visualize",
        "title": "GitLab CI: Visualize Pipeline"
      },
      {
        "command": "gitlabCiVisualizer.setToken",
        "title": "GitLab CI: Set Access Token"
      }
    ],
    "configuration": {
      "title": "GitLab CI Visualizer",
      "properties": {
        "gitlabCiVisualizer.instanceUrl": {
          "type": "string",
          "default": "https://gitlab.com",
          "description": "GitLab instance URL (e.g. https://gitlab.yourcompany.com)"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package": "npm run compile && npx vsce package",
    "publish": "npm run compile && npx vsce publish"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
